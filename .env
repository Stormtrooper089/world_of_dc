# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MongoDB Connection URI
# For local MongoDB (development)
MONGODB_URI=mongodb://mongodb:27017/cachar_complaints

# For MongoDB Atlas (production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cachar_complaints?retryWrites=true&w=majority

# Alternative MongoDB configuration (uncomment and modify if needed)
# MONGODB_HOST=localhost
# MONGODB_PORT=27017
# MONGODB_DATABASE=cachar_complaints
# MONGODB_USERNAME=cachar_user
# MONGODB_PASSWORD=your_password

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=mySecretKey123456789012345678901234567890

# JWT Token Expiration (in milliseconds)
JWT_EXPIRATION_MS=3600000

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Upload directory
FILE_UPLOAD_DIR=/app/uploads

# Maximum file size in bytes (10MB = 10485760 bytes)
FILE_MAX_SIZE=10485760

# =============================================================================
# SMS/OTP CONFIGURATION
# =============================================================================
# SMS Provider (console for development, twilio/aws/etc for production)
SMS_PROVIDER=console

# SMS API Key (get from your SMS provider)
SMS_API_KEY=your_sms_api_key

# SMS Sender ID
SMS_SENDER_ID=CACHAR

# =============================================================================
# COMPLAINT CONFIGURATION
# =============================================================================
# Complaint number prefix
COMPLAINT_NUMBER_PREFIX=CCR

# Complaint number length
COMPLAINT_NUMBER_LENGTH=18

# =============================================================================
# SPRING PROFILES
# =============================================================================
# Active Spring profile (dev/prod)
SPRING_PROFILES_ACTIVE=prod

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level for root
LOGGING_LEVEL_ROOT=WARN

# Log level for application
LOGGING_LEVEL_APP=INFO

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Server port
SERVER_PORT=8080

# Context path
SERVER_SERVLET_CONTEXT_PATH=/

# =============================================================================
# PRODUCTION SPECIFIC (MongoDB Atlas)
# =============================================================================
# Uncomment and configure these for MongoDB Atlas production deployment
# MONGODB_USERNAME=your_mongodb_atlas_username
# MONGODB_PASSWORD=your_mongodb_atlas_password
# MONGODB_CLUSTER=cluster0.mongodb.net
